# ================================================
# WhatsApp SaaS - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ================================================

# Banco de Dados (SQLite local no V1)
DATABASE_URL="file:./prisma/dev.db"

# IA
OPENAI_API_KEY="sk-proj-COLOQUE_SUA_CHAVE_AQUI"
OPENAI_MODEL="gpt-4o-mini"

# Identidade desta instância do robô (fixo por clínica)
# No V1 local, o backend também usa esta variável para referencias admin
CLINIC_ID="clinic-demo-id"

# Segurança (placeholder para auth futura na Fase 2)
NEXTAUTH_SECRET="placeholder-para-auth-futura-nunca-deixe-em-producao"

# URL do backend (usado pelo robô para chamar as APIs)
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000"
